<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
    function saveInvoiceAsPDF() {
        const element = document.querySelector('.a4-container');
        
        const options = {
            margin: 0,
            filename: 'Promo_Traders_Invoice.pdf',
            image: { type: 'jpeg', quality: 1.0 },
            html2canvas: { 
                scale: 2, 
                useCORS: true,
                logging: false,
                letterRendering: true,
                // Ensures the canvas is clipped to the exact A4 height
                height: 1122, // Approximate pixel height for A4 at 96 DPI
                windowHeight: 1122
            },
            jsPDF: { 
                unit: 'mm', 
                format: 'a4', 
                orientation: 'portrait',
                compress: true
            },
            // Force the library to treat the content as a single page
            pagebreak: { mode: 'avoid-all' }
        };

        // Generate the PDF
        html2pdf().set(options).from(element).toPdf().get('pdf').then(function (pdf) {
            // This extra step ensures that if a 2nd page was created, it's deleted
            const totalPages = pdf.internal.getNumberOfPages();
            for (let i = totalPages; i > 1; i--) {
                pdf.deletePage(i);
            }
        }).save();
    }
</script>

